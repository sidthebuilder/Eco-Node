# ── ElectricityMaps ────────────────────────────────────────────────────────────
# Free tier: https://electricitymaps.com/free-tier
# Leave empty to use realistic mock data (demo mode)
ELECTRICITY_MAPS_KEY=

# ── AWS (optional) ─────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

# ── GCP (optional) ─────────────────────────────────────────────────────────────
GOOGLE_APPLICATION_CREDENTIALS=

# ── Azure (optional) ───────────────────────────────────────────────────────────
AZURE_SUBSCRIPTION_ID=
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# ── AETHER tuning ──────────────────────────────────────────────────────────────
# Refresh interval (seconds) for carbon+price polling
AETHER_POLL_INTERVAL=300
# Minimum improvement threshold (%) before triggering a mid-run migration
AETHER_MIGRATION_THRESHOLD=0.15
# Predictor retraining interval (hours)
AETHER_RETRAIN_HOURS=6
# Max history rows kept in the rolling window
AETHER_HISTORY_LIMIT=2016
# Log level: DEBUG | INFO | WARNING | ERROR
AETHER_LOG_LEVEL=INFO
